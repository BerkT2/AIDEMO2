    <!-- VALIDATION RULE MESSAGES -->
    <!-- ============================================================ -->
    <validationRules>
        <name>Account.Rejection_Reason_Required</name>
        <errorMessage>Finans Onay Durumunu Reddedildi olarak ayarlamadan önce lütfen Red Gerekçesini giriniz.</errorMessage>
    </validationRules>
    <validationRules>
        <name>Account.Inactivity_Reason_Required</name>
        <errorMessage>Müşteri Durumunu Pasif veya Havuz olarak ayarlarken lütfen Hareketsizlik Nedenini giriniz.</errorMessage>
    </validationRules>
    <validationRules>
        <name>Account.Ownership_Reason_Required</name>
        <errorMessage>Pasif veya Havuzdaki bir cariyi sahiplenirken lütfen Sahiplenme Sebebini giriniz.</errorMessage>
    </validationRules>
    <validationRules>
        <name>Account.Tax_Number_Format</name>
        <errorMessage>Vergi Numarası tam olarak 10 hane (kurumsal) veya 11 hane (bireysel TCKN) olmalıdır.</errorMessage>
    </validationRules>
